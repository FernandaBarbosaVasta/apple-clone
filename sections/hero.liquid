<section>
    <div>
      {%- if section.settings.image != blank -%}
        <div class="with-image">
          <!-- Title, Description, and Buttons below the image -->
          <div class="content-container">
            <h1>{{ section.settings.title_text }}</h1> <!-- Title -->
            <p class="description">{{ section.settings.description_text }}</p> <!-- Description -->
           
            {%- if section.blocks.size == 0 -%}
              <div class="buttons">
                  <a href="#" class="button">Learn more</a>
                  <a href="#" class="button">Buy now</a>
                 </div>
            {% else %}
            <div class="buttons-dynamic">
              <a href="{{ block.settings.button_url }}" class="button">{{ block.settings.button_text | escape }}</a>
           </div>
           {% endif %}
  
  
           
          </div>
        </div>
      {%- else -%}
        <div class="default">
          <div class="content-container">
            <h1>{{ section.settings.title_text }}</h1> <!-- Title -->
            <p class="description">{{ section.settings.description_text }}</p> <!-- Description -->
          
  
            {%- if section.blocks.size == 0 -%}
              <div class="buttons">
                  <a href="#" class="button">Learn more</a>
                  <a href="#" class="button">Buy now</a>
                 </div>
            {% else %}
            {% for block in section.blocks %}
            <div class="buttons-dynamic">
              <a href="{{ block.settings.button_url }}" class="button">{{ block.settings.button_text | escape }}</a>
             </div>
           {% endfor %}
          {% endif %}
  
  
          </div>
        </div>
      {%- endif -%}
    </div>
  
   
  </section>
  
  
  <style>
     .default {
      background-image: url("{{ 'one.jpg' | asset_url }}");
      width: 100%;
      height: 700px;
      background-size: cover;
      background-position: center;
    }
    .with-image {
      background-image: url("{{ section.settings.image | image_url }}");
      width: 100%;
      height: 700px;
      background-size: cover;
      background-position: center;
    }
    .content-container {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: white;
    max-width: 80%;
    z-index: 2;
  }
  
  h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: black;
  
  }
  
  .description {
    font-size: 1.25rem;
    margin-bottom: 2rem;
    color: black;
  }
  
  .buttons {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 10px;
  }
  
  .buttons-dynamic {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 10px;
  }
  
  .button {
    margin: 1px;
    padding: 10px 20px;
    background-color: #007bff;
    color: white;
    text-decoration: none;
    border-radius: 25px;
    font-size: 1rem;
    transition: background-color 0.3s ease;
  }
  
  .button:hover {
    background-color: #0056b3;
  }
  
  @media screen and (max-width: 768px) {
    .content-container {
      max-width: 40%;
      top: 19%; 
    }
    h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: black;
  
  }
    .description {
    font-size: 1rem;
    margin-bottom: 2rem;
    color: black;
  }
  
  .buttons {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 10px;
  }
  
      .buttons-dynamic {
          display: flex;
          flex-direction: column;
          justify-content: center;
          gap: 10px;
      }
   
  }
  </style>
  
  
  {%  schema  %}  
  
  {
      "name": "hero",
      "settings": [
          {
          "type": "text",
          "id": "title_text",
          "label": "Title Text",
          "default": "Title Text"
          },
          {
          "type": "text",
          "id": "description_text",
          "label": "Description",
          "default": "This is a description that goes below the title"
          },
         {
          "type": "image_picker",
          "id": "image",
          "label": "image",
          "info": "400 x 120px .png recommended"
         }
      ],
  
      "blocks": [
          {
          "type": "text",
          "name": "text button",
          "settings": [
              {
              "type": "text",
              "id": "button_text",
              "label": "Button Text",
              "default": "Button"
              },
              {
               "type": "url",
               "id": "button_url",
               "label": "Button URL"
               }
          ]
          }
      ],
      "presets": [
          {
          "name": "hero"
          }
      ]
  }
  
  {% endschema %}