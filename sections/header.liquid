<nav class="header-nav">
    <div class="left-nav">
    {% comment %} <h1>{{ shop.name }}</h1> {% endcomment %}
    <a href="/">
      <img
        width="15"
        height="18"
        loading="lazy"
        src="{{ 'logo.svg' | asset_url }}"
      >
    </a>
    </div>

    <div class="middle-nav">
        <ul class="middle-nav-links">
          {% for link in linklists['main-menu'].links -%}
            <li>{{ link.title | link_to: link.url }}</li>
          {%- endfor %}
        </ul>
      </div>

    <div class="left-nav">
    <a href="/cart">
      <img
        width="20"
        height="23"
        loading="lazy"
        src="{{ 'cart.svg' | asset_url }}"
        alt="Cart"
      >
    </a>
    <p>{{cart.item_count}}</p>
    </div>
</nav>


<style>
    .shopping-img {
        cursor: 'pointer';
        margin-bottom: 10px;
      }
    
    .header-nav {
        display: flex;
        justify-content: space-between;
        margin: 0;
        padding: 1px;
        background-color: white;
        padding: 0 30px 0 30px;
      }

  
.left-nav {
  display: flex;
  align-items: center;
  position: relative;
}
    
      .middle-nav-links {
        display: flex;
        font-size: 16px;
      }
    
      .middle-nav-links li {
        list-style-type: none;
        padding-left: 10px;
        padding-right: 10px;
      }
    
      .middle-nav-links li:hover {
        text-decoration: underline;
      }
    
      .middle-nav-links a {
        text-decoration: none;
        color: inherit;
      }
    
      .right-nav-items {
        display: flex;
        align-items: center;
      }
      .search-nav {
        padding: 10px;
        margin-top: 10px;
        border-radius: 15px;
        border: none;
        background-color: rgb(239, 234, 234);
      }
      

.left-nav p {
  font-size: 14px;
  font-weight: bold;
  color: #333;  /* Dark text color */
  position: absolute;
  top: 10px;
  right: -13px;
  background-color: #196d8f;  /* Bright color for visibility */
  color: white;
  border-radius: 50%;
  padding: 4px 1px;
  font-size: 12px;  /* Smaller font size for item count */
  min-width: 18px;
  text-align: center;
  line-height: 1;
}



@media (max-width: 480px) {

.header-nav {
  padding-top: 10px;
}

.middle-nav {
  display: none;
}

    }


</style>


{%  schema  %}  

{
    "name": "header",
    "settings": [
        {
        "type": "text",
        "id": "header_text",
        "label": "Header Text",
        "default": "Hello World"
        }
    ],
    "presets": [
        {
        "name": "header"
        }
    ]
}

{% endschema %}